# Specter configuration. Copy to .env and fill in real values.

# Discord bot token (Bot -> Token in the Developer Portal). Never commit this.
DISCORD_TOKEN=

# OAuth2 application credentials (for the dashboard).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/auth/callback

# PostgreSQL connection string.
DATABASE_URL=postgres://specter:specter@localhost:5432/specter?sslmode=disable

# Dashboard.
DASHBOARD_PORT=8080
DASHBOARD_SESSION_SECRET=change-me-to-a-random-32-plus-character-string

# External tooling.
YTDLP_PATH=yt-dlp

# Logging: trace, debug, info, warn, error.
LOG_LEVEL=info

# production | development. In development, set DEV_GUILD_ID for instant
# slash-command updates scoped to a single test guild.
ENVIRONMENT=production
DEV_GUILD_ID=
