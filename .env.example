# Specter configuration — copy to `.env` and fill in real values.
#
#   cp .env.example .env && docker compose up -d
#
# For a Docker Compose deploy you only need to fill in the values in the
# "REQUIRED" and "RECOMMENDED" sections. The connection strings for Postgres and
# Lavalink are wired automatically by docker-compose.yml and are ignored by the
# containers, so you do NOT need to touch DATABASE_URL / LAVALINK_ADDRESS unless
# you run the bot outside Docker (e.g. `go run ./cmd/specter`).

# ============================ REQUIRED ============================

# Discord bot token (Developer Portal -> Bot -> Token). Never commit this.
DISCORD_TOKEN=

# OAuth2 application credentials (Developer Portal -> OAuth2). Needed for the
# web dashboard login.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Public URL Discord redirects back to after OAuth login. On a server this must
# be your real domain, e.g. https://specter.example.com/auth/callback, and the
# same value must be added as a redirect URI in the Developer Portal.
DISCORD_REDIRECT_URI=http://localhost:8080/auth/callback

# Session signing secret for the dashboard. MUST be at least 32 characters.
# Generate one with:  openssl rand -hex 32
DASHBOARD_SESSION_SECRET=

# ========================== RECOMMENDED ===========================

# Strong password for the bundled Postgres container (used by both the DB and
# the bot's connection string in docker-compose). Change it for any real deploy.
POSTGRES_PASSWORD=specter

# Password the bot uses to talk to Lavalink. Change it for any real deploy; it
# is applied to both the bot and the Lavalink container automatically.
LAVALINK_PASSWORD=youshallnotpass

# production = slash commands register GLOBALLY (visible in every server the bot
# joins). development + DEV_GUILD_ID = register to one test guild for instant
# updates while developing. DEV_GUILD_ID does NOT affect any logging.
ENVIRONMENT=production
DEV_GUILD_ID=

# Logging: trace, debug, info, warn, error.
LOG_LEVEL=info

# ============================ OPTIONAL ============================

# Spotify source. Create an app at https://developer.spotify.com to get these.
# Consumed by the Lavalink container (LavaSrc plugin), not the bot. YouTube,
# YouTube Music, and SoundCloud all work without them.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Channel where the bot logs every server it joins or is removed from (bot
# growth log). Leave blank to disable.
GUILD_JOIN_LOG_CHANNEL_ID=

# yt-dlp binary for the /tiktok and /ytdownload media commands (NOT music).
# Inside the Docker image this is already on PATH; only change for local runs.
YTDLP_PATH=yt-dlp

# ============ LOCAL-ONLY (ignored by Docker Compose) ============
# These are only used when running the bot directly with `go run`. In Docker,
# compose overrides them with the in-network service hostnames.
DATABASE_URL=postgres://specter:specter@localhost:5432/specter?sslmode=disable
LAVALINK_ADDRESS=localhost:2333
LAVALINK_SECURE=false
DASHBOARD_PORT=8080
