# Specter configuration. Copy to .env and fill in real values.

# Discord bot token (Bot -> Token in the Developer Portal). Never commit this.
DISCORD_TOKEN=

# OAuth2 application credentials (for the dashboard).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/auth/callback

# PostgreSQL connection string.
DATABASE_URL=postgres://specter:specter@localhost:5432/specter?sslmode=disable

# Dashboard.
DASHBOARD_PORT=8080
DASHBOARD_SESSION_SECRET=change-me-to-a-random-32-plus-character-string

# External tooling. yt-dlp powers the /tiktok and /ytdownload media commands
# (NOT music; music is handled by Lavalink below).
YTDLP_PATH=yt-dlp

# Lavalink audio node (music backend). Run it via `docker compose up -d lavalink`.
# When running the bot locally against the dockerized node, use localhost:2333.
LAVALINK_ADDRESS=localhost:2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Spotify source (optional). Create an app at https://developer.spotify.com to
# get these. They are consumed by the Lavalink container (LavaSrc plugin), not
# the bot. YouTube, YouTube Music, and SoundCloud work without them.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Logging: trace, debug, info, warn, error.
LOG_LEVEL=info

# production | development. In development, set DEV_GUILD_ID for instant
# slash-command updates scoped to a single test guild.
ENVIRONMENT=production
DEV_GUILD_ID=

# Channel where the bot logs every server it joins or is removed from (bot
# growth log). Leave blank to disable.
GUILD_JOIN_LOG_CHANNEL_ID=
